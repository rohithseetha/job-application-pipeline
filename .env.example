# Adzuna API credentials — register at https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=au

# Which LLM drafts the resume diff / cover letter: "gemini" (default, has a
# genuine free tier) or "anthropic". Both code paths are fully implemented in
# mcp_server/server.py.
LLM_PROVIDER=gemini

# Gemini API key — free, get one at https://aistudio.google.com/apikey
# (no billing account required for the free tier).
GEMINI_API_KEY=

# Optional — defaults to gemini-2.5-flash (free tier) in mcp_server/server.py.
GEMINI_MODEL=

# Anthropic API key — https://console.anthropic.com/ (only needed if
# LLM_PROVIDER=anthropic). Not required if you're authenticated via
# `ant auth login` (Anthropic CLI) — the SDK picks that up automatically.
# Either way you need API credit balance on the org (separate from a Claude
# Code/Claude.ai subscription).
ANTHROPIC_API_KEY=

# Optional — defaults to claude-haiku-4-5 (cheapest tier) in mcp_server/server.py.
# Bump to claude-opus-4-8 or claude-sonnet-5 for better drafting quality once
# you're comfortable with the cost.
ANTHROPIC_MODEL=

DATABASE_URL=sqlite:///./jobs.db
