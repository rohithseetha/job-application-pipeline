# Adzuna API credentials — register at https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=au

# Anthropic API key — https://console.anthropic.com/
# Not required if you're authenticated via `ant auth login` (Anthropic CLI) —
# the SDK picks that up automatically. Either way you need API credit balance
# on the org (separate from a Claude Code/Claude.ai subscription).
ANTHROPIC_API_KEY=

# Optional — defaults to claude-haiku-4-5 (cheapest tier) in mcp_server/server.py.
# Bump to claude-opus-4-8 or claude-sonnet-5 for better drafting quality once
# you're comfortable with the cost.
ANTHROPIC_MODEL=

DATABASE_URL=sqlite:///./jobs.db
